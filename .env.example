# Application
APP_NAME=project-pulse-kg
APP_ENV=dev
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Config
CONFIG_DIR=./configs
BASE_CONFIG_FILE=base.yaml
ENV_CONFIG_FILE=dev.yaml

# MySQL Warehouse
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=adbis_db
MYSQL_USER=change_me
MYSQL_PASSWORD=change_me
MYSQL_CONNECT_TIMEOUT=10

# Neo4j
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me
NEO4J_DATABASE=neo4j

# Metadata database (Postgres)
METADATA_DB_HOST=127.0.0.1
METADATA_DB_PORT=5432
METADATA_DB_NAME=project_pulse_metadata
METADATA_DB_USER=project_pulse
METADATA_DB_PASSWORD=change_me

# Pipeline
DEFAULT_BATCH_SIZE=5000
MAX_RETRIES=3
CHECKPOINT_NAMESPACE=project_pulse
FULL_BACKFILL_ENABLED=true
INCREMENTAL_SYNC_ENABLED=true

# Analytics / GDS
GDS_ENABLED=true
LEIDEN_GRAPH_NAME=hidden_tribes
LEIDEN_WEIGHT_THRESHOLD=0.5
LEIDEN_WRITE_PROPERTY=tribe_id

# API security
API_KEY_ENABLED=false
API_KEY_HEADER=X-API-Key
API_KEY_VALUE=change_me

# Observability
METRICS_ENABLED=true
TRACING_ENABLED=false

# Docker / local
WORKER_CONCURRENCY=2